{
  "private": true,
  "name": "kunkels.me",
  "version": "0.0.0",
  "repository": "git@github.com:chiel/kunkels.me.git",
  "author": "chielkunkels",
  "main": "dist/server",
  "scripts": {
    "build": "yarn build:client && yarn build:server",
    "build:client": "webpack --display errors-only",
    "build:server": "babel -D -d dist --ignore src/client src",
    "lint": "eslint .",
    "start": "node dist/server",
    "watch:build": "babel -w -D -d dist --ignore src/client src",
    "watch:client": "webpack --display errors-only -w",
    "watch:server": "nodemon -q -e js,json,md -w dist -i dist/public dist/server"
  },
  "dependencies": {
    "date-fns": "^1.29.0",
    "express": "^4.16.2",
    "js-yaml": "^3.11.0",
    "markdown-it": "^8.4.1",
    "markdown-it-front-matter": "^0.1.2",
    "prop-types": "^15.6.0",
    "react": "^16.2.0",
    "react-dom": "^16.2.0",
    "react-helmet": "^5.2.0",
    "react-redux": "^5.0.7",
    "react-router": "^3.0.0",
    "react-transition-group": "^2.2.1",
    "redux": "^3.7.2",
    "redux-observable": "^0.18.0",
    "reselect": "^3.0.1",
    "rxjs": "^5.5.7",
    "xhr2": "^0.1.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.0.0-beta.35",
    "@babel/core": "^7.0.0-beta.35",
    "@babel/preset-env": "^7.0.0-beta.35",
    "@babel/preset-react": "^7.0.0-beta.35",
    "@babel/preset-stage-2": "^7.0.0-beta.35",
    "babel-eslint": "^8.0.3",
    "babel-loader": "^8.0.0-beta.0",
    "copy-webpack-plugin": "^4.6.0",
    "eslint": "^4.9.0",
    "eslint-config-airbnb": "^16.1.0",
    "eslint-plugin-import": "^2.7.0",
    "eslint-plugin-jsx-a11y": "^6.0.2",
    "eslint-plugin-react": "^7.4.0",
    "modular-css-webpack": "^7.2.0",
    "nodemon": "^1.12.6",
    "postcss-color-function": "^4.0.1",
    "postcss-import": "^11.0.0",
    "postcss-inline-svg": "^3.0.0",
    "postcss-nested": "^3.0.0",
    "webpack": "^3.10.0"
  }
}
